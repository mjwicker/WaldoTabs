{
  "manifest_version": 3,
  "name": "Waldo Tabs",
  "version": "0.1.1",
  "description": "Agentic tab conductor — resource tracking, hibernation, AI automation, and puzzle solving for local-first research",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Waldo Tabs"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
