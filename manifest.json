{
  "manifest_version": 3,
  "name": "Waldo Tabs",
  "version": "0.3.1",
  "description": "Agentic tab conductor — resource tracking, hibernation, AI automation, and tab optimization for local-first research workflows",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "waldo-tabs@waldo.local",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      },
      "strict_min_version": "112.0"
    },
    "gecko_android": {
      "strict_min_version": "133.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Waldo Tabs"
  },
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_title": "Waldo Chat",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/readability.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
