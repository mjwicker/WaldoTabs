{
  "manifest_version": 3,
  "name": "Waldo Tabs",
  "version": "0.2.0",
  "description": "Agentic tab conductor — resource tracking, hibernation, AI automation, and tab optimization for local-first research workflows",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "waldo-tabs@waldo.local",
      "strict_min_version": "102"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Waldo Tabs"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
