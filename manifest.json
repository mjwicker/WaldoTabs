{
  "manifest_version": 3,
  "name": "Tab Agent Memory Optimizer",
  "version": "0.1.0",
  "description": "RAM-friendly tab hibernation with screenshot/summary capture for local AI agents",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Agent Optimizer"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
